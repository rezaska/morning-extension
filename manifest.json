{
  "manifest_version": 3,

  "name": "Morning!",
  "description": "Schedule a wellness break and get a countdown reminder.",
  "version": "1.0",
  "author": "Reza Soleimani",
  "action": {
    "default_icon": "./assets/morning.png",
    "default_popup": "./popup/popup.html",
    "default_title": "Morning!"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ]
}
